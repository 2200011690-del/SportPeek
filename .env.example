# Public application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_RUNTIME_USE_PUBLIC_KEY=false
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase key. Never prefix with NEXT_PUBLIC_ or expose to the browser.
# New projects should use SUPABASE_SECRET_KEY. The legacy service-role key remains supported.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Internal access. Public signup stays disabled for the small private team.
INTERNAL_MODE=true
ALLOW_PUBLIC_SIGNUP=false
ALLOWED_EMAILS=
ADMIN_EMAILS=

# AI: failover | gemini | groq | cloudflare | openai | off.
# Failover keeps the newsroom available without depending on one free quota.
AI_PROVIDER=failover
AI_PROVIDER_CHAIN=gemini,groq,cloudflare
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.1-8b-instruct-fast
CLOUDFLARE_AI_ACCOUNT_ID=
CLOUDFLARE_AI_API_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b

# Integrations and protected routes
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=
CRON_SECRET=
# Tin tổng hợp. Để trống để dùng mạng RSS NewsPeek mặc định đã kiểm tra.
# Có thể dùng JSON để khai báo tên, URL, độ tin cậy, ngôn ngữ, chuyên mục mặc định và cờ nguồn chính thức.
NEWS_PROVIDER=aggregated-rss
NEWS_RSS_FEEDS=

# Story reader: finite client wait and at most one retry. Fixtures are never used
# in production; the flag is reserved for explicit local development only.
NEXT_PUBLIC_STORY_DETAIL_TIMEOUT_MS=12000
NEXT_PUBLIC_STORY_DETAIL_RETRY_COUNT=1
ENABLE_DEVELOPMENT_FIXTURES=false
