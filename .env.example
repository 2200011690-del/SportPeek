# Public application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase key. Never prefix with NEXT_PUBLIC_ or expose to the browser.
# New projects should use SUPABASE_SECRET_KEY. The legacy service-role key remains supported.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI: mock | cloudflare | openai. Cloudflare uses a Worker binding, not an API key.
AI_PROVIDER=mock
CLOUDFLARE_AI_MODEL=@cf/meta/llama-3.1-8b-instruct-fast
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano

# Integrations and protected routes
TELEGRAM_BOT_TOKEN=
CRON_SECRET=demo-secret-change-me
ADMIN_EMAILS=admin@example.com
SPORTS_DATA_PROVIDER=mock
SPORTS_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITIONS=PL,CL,PD,SA,BL1,FL1,DED,PPL,BSA,ELC,WC
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
# IDs mặc định: Premier League, Champions League, La Liga, Serie A. Thêm ID V.League lấy từ dashboard API-Football.
API_FOOTBALL_LEAGUE_IDS=39,2,140,135
API_FOOTBALL_SEASON=2025

# Tin tổng hợp. Để trống để dùng 12 RSS mặc định: VFF, VPF, 6 báo Việt Nam và 4 báo quốc tế.
# Có thể dùng JSON để khai báo tên, URL, độ tin cậy, ngôn ngữ và cờ nguồn chính thức.
NEWS_PROVIDER=aggregated-rss
NEWS_RSS_FEEDS=
