{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sportpeek",
  "compatibility_date": "2026-05-22",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./worker/index.ts",
  "assets": {
    "directory": "dist/client",
    "not_found_handling": "none",
    "binding": "ASSETS",
  },
  "triggers": {
    "crons": ["* * * * *"],
  },
  "images": {
    "binding": "IMAGES",
  },
  "ai": {
    "binding": "AI",
  },
  "vars": {
    "NEXT_PUBLIC_APP_URL": "https://sportpeek.2200011690.workers.dev",
    "NEXT_PUBLIC_SUPABASE_URL": "https://atlvqdryzgsohbjglxng.supabase.co",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY": "sb_publishable_r5Ul01CZq9gJ-NhtbBP6DA_YmfNGYJg",
    "AI_PROVIDER": "failover",
    "AI_PROVIDER_CHAIN": "gemini,groq,cloudflare",
    "GEMINI_MODEL": "gemini-3.1-flash-lite",
    "GROQ_MODEL": "openai/gpt-oss-20b",
    "CLOUDFLARE_AI_MODEL": "@cf/meta/llama-3.2-1b-instruct",
    "SPORTS_DATA_PROVIDER": "football-data",
    "FOOTBALL_DATA_BASE_URL": "https://api.football-data.org/v4",
    "FOOTBALL_DATA_COMPETITIONS": "PL,CL,PD,SA,BL1,FL1,DED,PPL,BSA,ELC,WC,CLI",
    "API_FOOTBALL_BASE_URL": "https://v3.football.api-sports.io",
    "API_FOOTBALL_LEAGUE_IDS": "2,39,40,61,71,78,88,94,135,140",
    "API_FOOTBALL_SEASON": "2026",
    "API_FOOTBALL_FREE_SEASON": "2024",
    "OPENLIGADB_ENABLED": "true",
    "OPENLIGADB_COMPETITIONS": "bl2,bl3,dfb,ffb1,regio-bayern,BLSupercup,unl",
    "NEWS_PROVIDER": "aggregated-rss",
    "SUPABASE_RUNTIME_USE_PUBLIC_KEY": "false",
  },
}
