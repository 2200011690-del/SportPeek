{
  "name": "sportpeek",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "cross-env WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/unit/*.test.ts tests/integration/*.test.ts",
    "test:e2e": "node --test tests/e2e/smoke.test.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "format": "prettier --write . --ignore-path .gitignore",
    "format:check": "prettier --check . --ignore-path .gitignore",
    "setup": "node scripts/setup.mjs",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx supabase db push",
    "db:seed": "npx supabase db reset",
    "db:reset": "npx supabase db reset",
    "ingest:mock": "tsx scripts/ingest-mock.ts",
    "cron:demo": "tsx scripts/cron-demo.ts",
    "discover:providers": "tsx scripts/sports.ts providers",
    "discover:competitions": "tsx scripts/sports.ts competitions --dry-run",
    "sync:competitions": "tsx scripts/sports.ts competitions",
    "sync:teams": "tsx scripts/sports.ts teams",
    "sync:fixtures": "tsx scripts/sports.ts fixtures",
    "sync:results": "tsx scripts/sports.ts results",
    "sync:standings": "tsx scripts/sports.ts standings",
    "sync:live": "tsx scripts/sports.ts live",
    "sync:metadata": "tsx scripts/sports.ts teams",
    "report:coverage": "tsx scripts/sports.ts coverage"
    ,"rss:test": "tsx scripts/rss.ts test"
    ,"rss:sync": "tsx scripts/rss.ts sync"
    ,"rss:sync-source": "tsx scripts/rss.ts sync-source"
    ,"rss:report": "tsx scripts/rss.ts report"
    ,"stories:process": "tsx scripts/stories.ts process"
    ,"stories:recluster": "tsx scripts/stories.ts recluster"
    ,"stories:summarize": "tsx scripts/stories.ts summarize"
    ,"stories:retry-failed": "tsx scripts/stories.ts retry-failed"
    ,"stories:report": "tsx scripts/stories.ts report"
    ,"ops": "tsx scripts/ops.ts"
    ,"ops:health": "tsx scripts/ops.ts health"
    ,"ops:providers": "tsx scripts/ops.ts providers"
    ,"ops:failed-jobs": "tsx scripts/ops.ts failed-jobs"
    ,"ops:stale": "tsx scripts/ops.ts stale"
    ,"ops:conflicts": "tsx scripts/ops.ts conflicts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "0.45.2",
    "fast-xml-parser": "^5.10.0",
    "html-entities": "^2.6.0",
    "lucide-react": "^1.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "cross-env": "10.1.0",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.9.5",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "^4.23.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
